#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Fix PATH so pnpm works reliably from VS Code Source Control
export PATH="$(pnpm bin):$PATH"

echo "🔄 Automatically bumping patch version (0.0.1)..."

# Bump version by one patch
pnpm version patch --no-git-tag-version

# Update pnpm-lock.yaml
pnpm install --lockfile-only

echo "✅ Version bumped + lockfile updated. Files staged."

# Stage the version changes so they become part of this commit
git add package.json pnpm-lock.yaml