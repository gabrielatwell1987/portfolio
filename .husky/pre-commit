#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Fix PATH issues on Windows + VS Code (very important for pnpm)
export PATH="$(pnpm bin):$PATH"

echo "🔄 Bumping patch version..."

# Bump version by 0.0.1 (patch)
pnpm version patch --no-git-tag-version

# Update pnpm lockfile
pnpm install --lockfile-only

echo "✅ Version bumped and lockfile updated. Staging files..."

# Stage the version changes so they go into this commit
git add package.json pnpm-lock.yaml
