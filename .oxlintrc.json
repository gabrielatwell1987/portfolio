{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": [],
    "categories": {
        "correctness": "warn"
    },
    "env": {
        "browser": true,
        "es2024": true,
        "node": true,
        "builtin": true
    },
    "rules": {
        "no-undef": "off"
    },
    "ignorePatterns": [
        "node_modules",
        "dist",
        "build",
        ".svelte-kit",
        "static/threejayess/**",
        "**/*.min.js",
        "**/*-decoder.js"
    ],
    "overrides": [
        {
            "files": [
                "src/routes/**/*.svelte"
            ],
            "rules": {
                "no-unused-expressions": "off"
            }
        }
    ]
}